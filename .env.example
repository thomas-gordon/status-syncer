# Timezone (IANA format, e.g. Australia/Melbourne, Europe/London, America/New_York)
TZ="Australia/Melbourne"

# Database
DATABASE_URL="postgresql://statuswatcher:password@localhost:5432/statuswatcher"

# NextAuth
NEXTAUTH_URL="http://localhost:4100"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN="your-tunnel-token-here"

# Last.fm (get a key at https://www.last.fm/api/account/create)
LASTFM_API_KEY="your-lastfm-api-key"

# Slack OAuth
SLACK_CLIENT_ID="your-slack-client-id"
SLACK_CLIENT_SECRET="your-slack-client-secret"
